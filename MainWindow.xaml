<ui:FluentWindow x:Class="Kirin_Tool.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Kirin-Tool v2.4" Height="700" Width="1000"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <Grid x:Name="RootGrid">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Title="Kirin-Tool v2.4" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource BackgroundBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="16">
                            <TextBlock Text="CPU Model" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox x:Name="CpuComboBox">
                                <ComboBoxItem Content="Select CPU Model..." IsEnabled="False" IsSelected="True"/>
                                <ComboBoxItem Content="Kirin 65x_a (hisi65x_a)"/>
                                <ComboBoxItem Content="Kirin 65x_b (hisi65x_b)"/>
                                <ComboBoxItem Content="Kirin 620 (hisi620)"/>
                                <ComboBoxItem Content="Kirin 620c (hisi620c)"/>
                                <ComboBoxItem Content="Kirin 925 (hisi925)"/>
                                <ComboBoxItem Content="Kirin 935 (hisi935)"/>
                                <ComboBoxItem Content="Kirin 950 (hisi950)"/>
                                <ComboBoxItem Content="Kirin 955 (hisi955)"/>
                                <ComboBoxItem Content="Kirin 960 (hisi960)"/>
                                <ComboBoxItem Content="Kirin 970 (hisi970)"/>
                                <ComboBoxItem Content="Kirin 980 (hisi980)"/>
                                <ComboBoxItem Content="Kirin 985 (hisi985)"/>
                                <ComboBoxItem Content="Kirin 990 5G (hisi990)"/>
                                <ComboBoxItem Content="Kirin 710 (hisi710)"/>
                                <ComboBoxItem Content="Kirin 710a (hisi710a)"/>
                                <ComboBoxItem Content="Kirin 810 (hisi810)"/>
                                <ComboBoxItem Content="Kirin 820 (hisi820)"/>
                                <ComboBoxItem Content="Kirin K3v2 (hisik3v2)"/>
                            </ComboBox>
                        </StackPanel>

                        <ui:NavigationView Grid.Row="1"
                                      x:Name="NavigationView"
                                      IsBackButtonVisible="Collapsed"
                                      IsPaneToggleVisible="False"
                                      OpenPaneLength="320"
                                      PaneDisplayMode="Left"
                                      Margin="0,8,0,0">

                            <ui:NavigationView.MenuItems>
                                <ui:NavigationViewItem Content="Welcome"
                                                  Icon="{ui:SymbolIcon Home24}"
                                                  x:Name="WelcomeItem"/>
                                <ui:NavigationViewItem Content="Device Information"
                                                   Icon="{ui:SymbolIcon Info24}"
                                                   x:Name="DeviceInfoItem"/>
                                <ui:NavigationViewItem Content="VCOM Operations"
                                                  Icon="{ui:SymbolIcon UsbPlug24}"
                                                  x:Name="VcomItem"/>
                                <ui:NavigationViewItem Content="Flash Operations"
                                                  Icon="{ui:SymbolIcon Storage24}"
                                                  x:Name="FlashItem"/>
                                <ui:NavigationViewItem Content="Security Tools"
                                                  Icon="{ui:SymbolIcon Shield24}"
                                                  x:Name="SecurityItem"/>
                                <ui:NavigationViewItem Content="OEMInfo Tools"
                                                  Icon="{ui:SymbolIcon ShieldQuestion24}"
                                                  x:Name="OEMInfoItem"/>
                                <ui:NavigationViewItem Content="NVMe Tools"
                                                  Icon="{ui:SymbolIcon Tag24}"
                                                  x:Name="NVMeItem"/>
                                <ui:NavigationViewItem Content="About"
                                                  Icon="{ui:SymbolIcon Info24}"
                                                  x:Name="AboutItem"/>
                            </ui:NavigationView.MenuItems>

                        </ui:NavigationView>
                   </Grid>
                </Border>

                <ScrollViewer Grid.Column="1" 
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled">

                    <Grid x:Name="ContentContainer">

                        <StackPanel x:Name="WelcomePage" Margin="40,32,40,32">
                            <TextBlock Text="Welcome to Kirin-Tool" 
                                  FontSize="32" 
                                  FontWeight="Light"
                                  Margin="0,0,0,16"/>

                            <TextBlock Text="The best free tool to deal with HiSilicon Kirin devices"
                                  FontSize="16"
                                  Foreground="{StaticResource SecondaryTextBrush}"
                                  Margin="0,0,0,32"/>

                            <ui:CardExpander Header="Quick Start Guide"
                                        Icon="{ui:SymbolIcon Home12}"
                                        Margin="0,0,0,16"
                                        IsExpanded="True">
                                <StackPanel>
                                    <ui:CardControl Header="Step 1: Select CPU Model">
                                        <TextBlock Text="Choose your device's CPU model from the dropdown above" 
                                              FontSize="12" 
                                              Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>
                                    <ui:CardControl Header="Step 2: Connect Device">
                                        <TextBlock 
                                              FontSize="12" 
                                              Foreground="{StaticResource SecondaryTextBrush}">
                                    Connect your device in VCOM (USB COM 1.0) mode <LineBreak /> Make sure that the drivers are installed ;)
                                        </TextBlock>
                                    </ui:CardControl>
                                    <ui:CardControl Header="Step 3: Choose Operation">
                                        <TextBlock Text="Navigate to the appropriate section for your desired operation" 
                                              FontSize="12" 
                                              Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>
                                </StackPanel>
                            </ui:CardExpander>

                            <ui:InfoBar Title="Important Notice"
                                   Message="We are not responsible for any kind of damage you do with this tool. Use it at your own risk."
                                   Severity="Warning"
                                   IsOpen="True"
                                   Margin="0,16,0,0"/>

                            <ui:InfoBar Title="Beware!"
                                   Message="Kirin-Tool is free software. If you have paid for this tool, you have been scammed - please ask for a refund immediately!"
                                   Severity="Warning"
                                   IsOpen="True"
                                   Margin="0,8,0,0"/>

                        </StackPanel>

                        <StackPanel x:Name="DeviceInfoPage" Margin="40,32,40,32" Visibility="Collapsed">
                            <TextBlock Text="Device Information" 
                                   FontSize="28" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                            <TextBlock Text="Connected Device Details"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,0,0,32"/>

                            <ui:CardExpander x:Name="DeviceInfoExpander"
                                         Header="Information"
                                         Icon="{ui:SymbolIcon Info24}"
                                         Margin="0,0,0,4"
                                         IsExpanded="False">
                                <StackPanel>
                                    <ui:CardControl Header="FB Lock"
                                                   Icon="{ui:SymbolIcon LockShield24}">
                                        <TextBlock x:Name="InfoFbLock" 
                                                 Text="Not Read"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>

                                    <ui:CardControl Header="User Lock"
                                                   Icon="{ui:SymbolIcon PersonLock24}">
                                        <TextBlock x:Name="InfoUserLock" 
                                                 Text="Not Read"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>

                                    <ui:CardControl Header="Device Model"
                                                   Icon="{ui:SymbolIcon Phone24}">
                                        <TextBlock x:Name="InfoDeviceModel" 
                                                 Text="Not Read"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>
                                    
                                    <ui:CardControl Header="Vendor / Country"
                                                   Icon="{ui:SymbolIcon Globe24}">
                                        <TextBlock x:Name="InfoVendorCountry" 
                                                 Text="Not Read"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>

                                    <ui:CardControl Header="Build Number"
                                                   Icon="{ui:SymbolIcon NumberSymbol24}">
                                        <TextBlock x:Name="InfoBuildNumber" 
                                                 Text="Not Read"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>

                                    <ui:CardControl Header="Base Version"
                                                   Icon="{ui:SymbolIcon Box24}">
                                        <TextBlock x:Name="InfoBaseVersion" 
                                                 Text="Not Read"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>

                                    <ui:CardControl Header="Custom Version"
                                                   Icon="{ui:SymbolIcon Settings24}">
                                        <TextBlock x:Name="InfoCustomVersion" 
                                                 Text="Not Read"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>

                                    <ui:CardControl Header="Preload Version"
                                                   Icon="{ui:SymbolIcon ArrowDownload24}">
                                        <TextBlock x:Name="InfoPreloadVersion" 
                                                 Text="Not Read"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource SecondaryTextBrush}"/>
                                    </ui:CardControl>
                                </StackPanel>
                            </ui:CardExpander>

                            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                <ui:Button Content="Read Info"
                                           Appearance="Primary"
                                           Icon="{ui:SymbolIcon Search24}"
                                           Width="140"
                                           Height="40"
                                           Margin="0,0,16,0"
                                           Click="ReadDeviceInfo_Click"/>
                                
                                <ui:Button Content="Reboot"
                                           Icon="{ui:SymbolIcon Power24}"
                                           Width="140"
                                           Height="40"
                                           Click="RebootDevice_Click"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="VcomPage" Margin="40,32,40,32" Visibility="Collapsed">
                            <TextBlock Text="VCOM Operations" 
                                  FontSize="28" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>

                            <TextBlock Text="Boot into an unlocked fastboot state from VCOM (USB COM 1.0) mode"
                                  FontSize="14"
                                  Foreground="{StaticResource SecondaryTextBrush}"
                                  Margin="0,0,0,32"/>

                            <ui:CardExpander Header="Device Operations"
                                        Icon="{ui:SymbolIcon UsbPlug24}"
                                        Margin="0,0,0,4"
                                        IsExpanded="True">
                                <StackPanel>
                                    <Grid Margin="0,8,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Unlock Fastboot"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,4"/>
                                            <TextBlock Text="Put device into unlocked fastboot state"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                            <ui:ToggleSwitch x:Name="UseFastFlashLoaderSwitch"
                                                   Content="Use FastFlash loader"
                                                   Visibility="Collapsed"
                                                   Margin="0,16,0,0" />
                                        </StackPanel>

                                        <ui:Button Grid.Column="1"
                                               Content="Unlock"
                                               Appearance="Primary"
                                               Width="100"
                                               Height="40"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Tag="unlock-fastboot"
                                               Click="OperationButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </ui:CardExpander>

                            <ui:CardExpander Header="Software Testpoint"
                                         Icon="{ui:SymbolIcon UsbPlug24}"
                                         Margin="0,0,0,16"
                                         IsExpanded="False">
                                <StackPanel>
                                    <TextBlock Text="Put your device into VCOM mode without disassembling it"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,16"/>

                                    <ui:InfoBar Title="Important notice"
                                       Message="This feature only works on softwares before the 2021 February security patch (EMUI 10 and older), if you are running a newer system, please downgrade to use this feature. &#10;&#10;For the UPDATE file use a Base UPDATE.APP from the exact or newer firmware your device is currently running."
                                       Severity="Warning"
                                       IsOpen="True"
                                       Margin="0,16,0,0"/>

                                    <Grid Margin="0,8,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Grid.Column="0" 
                                                 PlaceholderText="Base UPDATE.APP"
                                                 Text="{Binding SwTpUpdateFile.FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="True"
                                                 Margin="0,0,8,0"/>
                                        <ui:Button Grid.Column="1"
                                               Content="Browse"
                                               Icon="{ui:SymbolIcon FolderOpen16}"
                                               Tag="SwTpUpdate"
                                               Click="BrowseOtaFile_Click"
                                               Margin="0,0,4,0"/>
                                        <ui:Button Grid.Column="2" 
                                               Content="Clear" 
                                               Icon="{ui:SymbolIcon Delete16}"
                                               Tag="SwTpUpdate"
                                               Click="ClearOtaFile_Click" 
                                               IsEnabled="{Binding SwTpUpdateFile.HasFile, Mode=OneWay}"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <ui:Button Content="Enter"
                                               Appearance="Primary"
                                               Width="100"
                                               Height="40"
                                               Margin="0,0,8,0"
                                               Tag="sw-testpoint-enter"
                                               Click="OperationButton_Click"/>
                                        <ui:Button Content="Exit"
                                               Appearance="Secondary"
                                               Width="100"
                                               Height="40"
                                               Tag="sw-testpoint-exit"
                                               Click="OperationButton_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardExpander>
                        </StackPanel>

                        <StackPanel x:Name="FlashPage" Margin="40,32,40,32" Visibility="Collapsed">
                            <TextBlock Text="Flash Operations" 
                                  FontSize="28" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>

                            <TextBlock Text="Flash firmware and system images"
                                  FontSize="14"
                                  Foreground="{StaticResource SecondaryTextBrush}"
                                  Margin="0,0,0,32"/>

                            <ui:CardExpander Header="Full OTA Flash"
                                         Icon="{ui:SymbolIcon CloudSync24}"
                                         Margin="0,0,0,16"
                                         IsExpanded="True">
                                <StackPanel>
                                    <TextBlock Text="Do a complete flash of your device"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,0,0,16"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <RadioButton Content="Fastboot Mode" 
                                                   IsChecked="{Binding IsFastbootUpdateSelected, Mode=TwoWay}"
                                                   Margin="0,0,24,0"/>
                                        <RadioButton Content="USB Update Mode" 
                                                   IsChecked="{Binding IsUsbUpdateSelected, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                            Text="Base PTABLE" 
                                            FontWeight="SemiBold" 
                                            FontSize="12"
                                            VerticalAlignment="Center"/>

                                        <ui:TextBox Grid.Column="1" 
                                            x:Name="BasePtablePathText"
                                            Text="{Binding BasePtableFile.FileName, Mode=OneWay}" 
                                            IsReadOnly="True"
                                            PlaceholderText="No file selected"
                                            Margin="8,0"/>

                                        <ui:Button Grid.Column="2" 
                                            Content="Browse" 
                                            Icon="{ui:SymbolIcon FolderOpen16}"
                                            Tag="BasePtable"
                                            Click="BrowseOtaFile_Click" 
                                            Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="3" 
                                            Content="Edit" 
                                            Icon="{ui:SymbolIcon Edit16}"
                                            Tag="BasePtable"
                                            Click="EditOtaFile_Click" 
                                            IsEnabled="{Binding BasePtableFile.IsEditEnabled, Mode=OneWay}"
                                            Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="4" 
                                            Content="Clear" 
                                            Icon="{ui:SymbolIcon Delete16}"
                                            Tag="BasePtable"
                                            Click="ClearOtaFile_Click" 
                                            IsEnabled="{Binding BasePtableFile.HasFile, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                           Text="Base UPDATE" 
                                           FontWeight="SemiBold" 
                                           FontSize="12"
                                           VerticalAlignment="Center"/>

                                        <ui:TextBox Grid.Column="1" 
                                            x:Name="BaseUpdatePathText"
                                            Text="{Binding BaseUpdateFile.FileName, Mode=OneWay}" 
                                            IsReadOnly="True"
                                            PlaceholderText="No file selected"
                                            Margin="8,0"/>

                                        <ui:Button Grid.Column="2" 
                                           Content="Browse" 
                                           Icon="{ui:SymbolIcon FolderOpen16}"
                                           Tag="BaseUpdate"
                                           Click="BrowseOtaFile_Click" 
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="3" 
                                           Content="Edit" 
                                           Icon="{ui:SymbolIcon Edit16}"
                                           Tag="BaseUpdate"
                                           Click="EditOtaFile_Click" 
                                           IsEnabled="{Binding BaseUpdateFile.IsEditEnabled, Mode=OneWay}"
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="4" 
                                           Content="Clear" 
                                           Icon="{ui:SymbolIcon Delete16}"
                                           Tag="BaseUpdate"
                                           Click="ClearOtaFile_Click" 
                                           IsEnabled="{Binding BaseUpdateFile.HasFile, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8" Visibility="{Binding IsUsbUpdateSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                           Text="Cust PTABLE" 
                                           FontWeight="SemiBold" 
                                           FontSize="12"
                                           VerticalAlignment="Center"/>

                                        <ui:TextBox Grid.Column="1" 
                                            x:Name="CustPtablePathText"
                                            Text="{Binding CustPtableFile.FileName, Mode=OneWay}" 
                                            IsReadOnly="True"
                                            PlaceholderText="No file selected"
                                            Margin="8,0"/>

                                        <ui:Button Grid.Column="2" 
                                           Content="Browse" 
                                           Icon="{ui:SymbolIcon FolderOpen16}"
                                           Tag="CustPtable"
                                           Click="BrowseOtaFile_Click" 
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="3" 
                                           Content="Edit" 
                                           Icon="{ui:SymbolIcon Edit16}"
                                           Tag="CustPtable"
                                           Click="EditOtaFile_Click" 
                                           IsEnabled="False"
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="4" 
                                           Content="Clear" 
                                           Icon="{ui:SymbolIcon Delete16}"
                                           Tag="CustPtable"
                                           Click="ClearOtaFile_Click" 
                                           IsEnabled="{Binding CustPtableFile.HasFile, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                           Text="Cust UPDATE" 
                                           FontWeight="SemiBold" 
                                           FontSize="12"
                                           VerticalAlignment="Center"/>

                                        <ui:TextBox Grid.Column="1" 
                                            x:Name="CustUpdatePathText"
                                            Text="{Binding CustUpdateFile.FileName, Mode=OneWay}" 
                                            IsReadOnly="True"
                                            PlaceholderText="No file selected"
                                            Margin="8,0"/>

                                        <ui:Button Grid.Column="2" 
                                           Content="Browse" 
                                           Icon="{ui:SymbolIcon FolderOpen16}"
                                           Tag="CustUpdate"
                                           Click="BrowseOtaFile_Click" 
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="3" 
                                           Content="Edit" 
                                           Icon="{ui:SymbolIcon Edit16}"
                                           Tag="CustUpdate"
                                           Click="EditOtaFile_Click" 
                                           IsEnabled="{Binding CustUpdateFile.IsEditEnabled, Mode=OneWay}"
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="4" 
                                           Content="Clear" 
                                           Icon="{ui:SymbolIcon Delete16}"
                                           Tag="CustUpdate"
                                           Click="ClearOtaFile_Click" 
                                           IsEnabled="{Binding CustUpdateFile.HasFile, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8" Visibility="{Binding IsUsbUpdateSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                           Text="Preload PTABLE" 
                                           FontWeight="SemiBold" 
                                           FontSize="12"
                                           VerticalAlignment="Center"/>

                                        <ui:TextBox Grid.Column="1" 
                                            x:Name="PreloadPtablePathText"
                                            Text="{Binding PreloadPtableFile.FileName, Mode=OneWay}" 
                                            IsReadOnly="True"
                                            PlaceholderText="No file selected"
                                            Margin="8,0"/>

                                        <ui:Button Grid.Column="2" 
                                           Content="Browse" 
                                           Icon="{ui:SymbolIcon FolderOpen16}"
                                           Tag="PreloadPtable"
                                           Click="BrowseOtaFile_Click" 
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="3" 
                                           Content="Edit" 
                                           Icon="{ui:SymbolIcon Edit16}"
                                           Tag="PreloadPtable"
                                           Click="EditOtaFile_Click" 
                                           IsEnabled="False"
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="4" 
                                           Content="Clear" 
                                           Icon="{ui:SymbolIcon Delete16}"
                                           Tag="PreloadPtable"
                                           Click="ClearOtaFile_Click" 
                                           IsEnabled="{Binding PreloadPtableFile.HasFile, Mode=OneWay}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                           Text="Preload UPDATE" 
                                           FontWeight="SemiBold" 
                                           FontSize="12"
                                           VerticalAlignment="Center"/>

                                        <ui:TextBox Grid.Column="1" 
                                            x:Name="PreloadUpdatePathText"
                                            Text="{Binding PreloadUpdateFile.FileName, Mode=OneWay}" 
                                            IsReadOnly="True"
                                            PlaceholderText="No file selected"
                                            Margin="8,0"/>

                                        <ui:Button Grid.Column="2" 
                                           Content="Browse" 
                                           Icon="{ui:SymbolIcon FolderOpen16}"
                                           Tag="PreloadUpdate"
                                           Click="BrowseOtaFile_Click" 
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="3" 
                                           Content="Edit" 
                                           Icon="{ui:SymbolIcon Edit16}"
                                           Tag="PreloadUpdate"
                                           Click="EditOtaFile_Click" 
                                           IsEnabled="{Binding PreloadUpdateFile.IsEditEnabled, Mode=OneWay}"
                                           Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="4" 
                                           Content="Clear" 
                                           Icon="{ui:SymbolIcon Delete16}"
                                           Tag="PreloadUpdate"
                                           Click="ClearOtaFile_Click" 
                                           IsEnabled="{Binding PreloadUpdateFile.HasFile, Mode=OneWay}"/>
                                        </Grid>

                                    <Border Background="{StaticResource BackgroundBrush}" 
                                        CornerRadius="8" 
                                        Padding="16" 
                                        Margin="0,16,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="Full OTA Status"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,0,0,4"/>
                                                <TextBlock x:Name="FullOtaStatusText" 
                                                   Text="{Binding FullOtaStatusMessage, Mode=OneWay}" 
                                                   FontSize="12" 
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                            </StackPanel>

                                            <ui:InfoBar Grid.Row="1" 
                                                Grid.ColumnSpan="2"
                                                Title="Incomplete OTA Warning" 
                                                Message="{Binding FullOtaWarningMessage, Mode=OneWay}"
                                                Severity="Warning"
                                                IsOpen="{Binding ShowFullOtaWarning, Mode=OneWay}"
                                                Margin="0,8,0,8"/>

                                            <ui:Button Grid.Row="2" Grid.Column="1"
                                               x:Name="StartFullOtaButton"
                                               Icon="{ui:SymbolIcon CloudSync24}"
                                               Appearance="Primary"
                                               IsEnabled="{Binding CanStartFullOta, Mode=OneWay}"
                                               Click="StartFullOtaButton_Click"
                                               Width="140"
                                               Height="40">
                                                <ui:Button.Content>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Start"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowFullOtaWarning, Mode=OneWay}" Value="True">
                                                                        <Setter Property="Text" Value="Start"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </ui:Button.Content>
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ui:CardExpander>

                            <ui:CardExpander Header="Enable Downgrade"
                                         Icon="{ui:SymbolIcon ArrowDownload24}"
                                         Margin="0,0,0,16"
                                         IsExpanded="False">
                                <StackPanel>
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Enable Downgrade"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,4"/>
                                            <TextBlock Text="With this option you can enable the ability to flash older firmwares from USB Update mode (requires unlocked fastboot)"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <ui:Button Grid.Column="1"
                                               Content="Enable"
                                               Appearance="Primary"
                                               Icon="{ui:SymbolIcon Checkmark24}"
                                               Width="120"
                                               Height="40"
                                               Margin="16,0,0,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Tag="enable-downgrade"
                                               Click="OperationButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </ui:CardExpander>

                            <ui:CardExpander Header="Reboot to USB Update"
                                         Icon="{ui:SymbolIcon ArrowSync24}"
                                         Margin="0,0,0,16"
                                         IsExpanded="False">
                                <StackPanel Margin="0,8,0,8">
                                    <TextBlock Text="Reboot to USB Update"
                                           FontWeight="SemiBold"
                                           FontSize="16"
                                           Margin="0,0,0,4"/>
                                    <TextBlock Text="Reboot to USB Update mode from fastboot mode"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SecondaryTextBrush}"/>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:TextBox Grid.Column="0" 
                                                 PlaceholderText="Base UPDATE.APP"
                                                 Text="{Binding UsbUpdateFile.FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="True"
                                                 Margin="0,0,8,0"/>

                                        <ui:Button Grid.Column="1"
                                               Content="Browse"
                                               Icon="{ui:SymbolIcon FolderOpen16}"
                                               Tag="UsbUpdate"
                                               Click="BrowseOtaFile_Click"
                                               Margin="0,0,4,0"/>

                                        <ui:Button Grid.Column="2" 
                                               Content="Clear" 
                                               Icon="{ui:SymbolIcon Delete16}"
                                               Tag="UsbUpdate"
                                               Click="ClearOtaFile_Click" 
                                               IsEnabled="{Binding UsbUpdateFile.HasFile, Mode=OneWay}"/>
                                    </Grid>

                                    <ui:Button Content="Reboot"
                                           Appearance="Primary"
                                           Icon="{ui:SymbolIcon Power24}"
                                           Width="140"
                                           Height="40"
                                           HorizontalAlignment="Right"
                                           Margin="0,16,0,0"
                                           Tag="reboot-usb-update"
                                           Click="OperationButton_Click"/>
                                </StackPanel>
                            </ui:CardExpander>

                            <ui:CardExpander Header="Fastboot Flasher"
                                         Icon="{ui:SymbolIcon PhoneLaptop24}"
                                         Margin="0,0,0,16"
                                         IsExpanded="False">
                                <StackPanel>
                                    <TextBlock Text="Dump partitions from device or flash images (requires unlocked fastboot)"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       Margin="0,8,0,16"/>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Dump Partitions"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                            <TextBlock Text="Extract partitions from connected device (810, 820, 985 not supported)"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <ui:Button Grid.Column="1"
                                           Content="Dump"
                                           Icon="{ui:SymbolIcon ArrowDownload24}"
                                           Width="140"
                                           Height="40"
                                           Click="DumpPartitions_Click"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Flash Partitions"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Margin="0,0,0,4"/>
                                            <TextBlock Text="Flash partition images from XML"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <ui:Button Grid.Column="1"
                                           Content="Flash"
                                           Icon="{ui:SymbolIcon ArrowUpload24}"
                                           Appearance="Primary"
                                           Width="140"
                                           Height="40"
                                           Click="FlashFromXml_Click"/>
                                    </Grid>
                                </StackPanel>
                            </ui:CardExpander>

                        </StackPanel>

                        <StackPanel x:Name="SecurityPage" Margin="40,32,40,32" Visibility="Collapsed">
                            <TextBlock Text="Security Tools" 
                                  FontSize="28" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>

                            <TextBlock Text="Bypass security locks and restrictions"
                                  FontSize="14"
                                  Foreground="{StaticResource SecondaryTextBrush}"
                                  Margin="0,0,0,32"/>

                            <ui:CardExpander Header="Security Bypass"
                                        Icon="{ui:SymbolIcon Shield24}"
                                        Margin="0,0,0,4"
                                        IsExpanded="True">
                                <StackPanel>
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="FRP Lock Removal"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,4"/>
                                            <TextBlock Text="Remove Factory Reset Protection lock  (requires unlocked fastboot)"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <ui:Button Grid.Column="1"
                                               Content="Remove FRP"
                                               Appearance="Caution"
                                               Width="100"
                                               Height="40"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Tag="frp-remove"
                                               Click="OperationButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </ui:CardExpander>

                            <ui:CardExpander Header="Unlocking"
                                        Icon="{ui:SymbolIcon LockOpen24}"
                                        Margin="0,16,0,4"
                                        IsExpanded="True"
                                        x:Name="UnlockBootloaderPanel"
                                        Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Unlock Bootloader"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,4"/>
                                            <TextBlock Text="Unlock the device's bootloader (requires unlocked fastboot)"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <ui:Button Grid.Column="1"
                                               Content="Unlock"
                                               Appearance="Primary"
                                               Width="100"
                                               Height="40"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Tag="unlock-bootloader"
                                               Click="OperationButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </ui:CardExpander>
                        </StackPanel>

                        <StackPanel x:Name="OEMInfoPage" Margin="40,32,40,32" Visibility="Collapsed">
                            <TextBlock Text="OEMInfo Tools" 
                                  FontSize="28" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>

                            <TextBlock Text="Convert your OEMInfo files"
                                  FontSize="14"
                                  Foreground="{StaticResource SecondaryTextBrush}"
                                  Margin="0,0,0,32"/>

                            <ui:CardExpander Header="OEMInfo Converter"
                                        Icon="{ui:SymbolIcon ArrowSwap24}"
                                        Margin="0,0,0,4"
                                        IsExpanded="True">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Convert OEMInfo"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               Margin="0,0,0,4"/>

                                        <TextBlock Text="Convert your OEMInfo to your desired version (requires unlocked fastboot)"
                                               FontSize="12"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Margin="0,0,0,16"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <ui:ToggleSwitch x:Name="TogLivePull" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="devSwtxt" Text="Get OEMInfo from device" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" x:Name="FileSelectionPanel">
                                            <TextBlock Text="OEMInfo File:" Width="120" VerticalAlignment="Center"/>
                                            <ui:TextBox Width="200" x:Name="TxtOemInfoFile" PlaceholderText="Select OEMInfo file" Margin="0,0,8,0"/>
                                            <ui:Button Content="Browse" Icon="{ui:SymbolIcon FolderOpen24}" Click="BrowseOemInfoFile_Click"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Device Model:" Width="120" VerticalAlignment="Center"/>
                                            <ui:TextBox Width="200" x:Name="TxtDeviceModel" PlaceholderText="e.g. VOG-AL00"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="Vendor/Country:" Width="120" VerticalAlignment="Center"/>
                                            <ui:TextBox Width="200" x:Name="TxtVendor" PlaceholderText="e.g. all/cn"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <ui:Button Grid.Column="1"
                                           Content="Convert"
                                           Appearance="Primary"
                                           Width="100"
                                           Height="40"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           x:Name="BtnConvertOem"
                                           Click="BtnConvertOem_Click"/>
                               </Grid>
                            </ui:CardExpander>
                        </StackPanel>

                        <StackPanel x:Name="NVMePage" Margin="40,32,40,32" Visibility="Collapsed">
                            <TextBlock Text="NVMe Tools" 
                                  FontSize="28" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>

                            <TextBlock Text="Manage values stored in the device's NVMe"
                                  FontSize="14"
                                  Foreground="{StaticResource SecondaryTextBrush}"
                                  Margin="0,0,0,32"/>

                            <ui:CardExpander Header="Serial Number Management"
                                        Icon="{ui:SymbolIcon Tag24}"
                                        Margin="0,0,0,4"
                                        IsExpanded="True">
                                <StackPanel>
                                    <Grid Margin="0,8,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Current Serial Number"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,4"/>
                                            <TextBlock Text="Read the current device serial number"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,0,0,8"/>
                                            <TextBlock Text="---" 
                                                   FontFamily="Consolas" 
                                                   FontSize="12" 
                                                   x:Name="CurrentSerialDisplay"/>
                                        </StackPanel>

                                        <ui:Button Grid.Column="1"
                                               Content="Read SN"
                                               Icon="{ui:SymbolIcon Eye24}"
                                               Width="100"
                                               Height="40"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Tag="read-sn"
                                               Click="OperationButton_Click"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Write New Serial Number"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Margin="0,0,0,4"/>
                                            <TextBlock Text="Enter new serial number (requires unlocked fastboot)"
                                                   FontSize="12"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Margin="0,0,0,8"/>
                                            <ui:TextBox x:Name="NewSerialInput" 
                                                    PlaceholderText="Enter new serial number" 
                                                    Width="300"
                                                    HorizontalAlignment="Left"/>
                                        </StackPanel>

                                        <ui:Button Grid.Column="1"
                                               Content="Write SN"
                                               Icon="{ui:SymbolIcon Save24}"
                                               Appearance="Primary"
                                               Width="100"
                                               Height="40"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Tag="write-sn"
                                               Click="OperationButton_Click"/>
                                    </Grid>
                                </StackPanel>
                            </ui:CardExpander>
                        </StackPanel>

                        <StackPanel x:Name="AboutPage" Margin="40,32,40,32" Visibility="Collapsed">
                            <TextBlock Text="About Kirin-Tool" 
                                  FontSize="28" 
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,8"/>

                            <TextBlock Text="Version information and credits"
                                  FontSize="14"
                                  Foreground="{StaticResource SecondaryTextBrush}"
                                  Margin="0,0,0,32"/>

                            <ui:CardExpander Header="About and Credits"
                                        Icon="{ui:SymbolIcon Info24}"
                                        Margin="0,0,0,4"
                                        IsExpanded="True">
                                <StackPanel>
                                    <TextBlock Text="Kirin-Tool v2.4" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="© Kethily Daniel and NDXCode" 
                                          FontSize="14" 
                                          Foreground="{StaticResource SecondaryTextBrush}"
                                          Margin="0,0,0,16"/>
                                    <TextBlock Text="Credits:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                                    <TextBlock Text="• TASZK Security Labs SL - Bootrom exploit" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBlock Text="• kasnria001 - Decrypted XLOADERs and lots of help in general" FontSize="12" Margin="0,0,0,16"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <ui:Button Content="Kirin-Tool Guide" Icon="{ui:SymbolIcon Book24}" Click="HelpButton_Click" Margin="0,0,8,0"/>
                                        <ui:Button Content="Telegram Support" Icon="{ui:SymbolIcon Send24}" Click="TelegramButton_Click" Margin="0,0,8,0"/>
                                        <ui:Button Content="GitHub" Icon="{ui:SymbolIcon Code24}" Click="GithubButton_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </ui:CardExpander>
                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </Grid>
            <ContentPresenter x:Name="RootContentDialog" Grid.RowSpan="2"/>

        <Grid x:Name="GlobalInteractionOverlay" Grid.RowSpan="2" Visibility="Collapsed">
            <Border Background="#91000000"/>

            <Border Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#D1D1D1" 
                    BorderThickness="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    MaxWidth="600"
                    Padding="64,40">
                <StackPanel>
                    <TextBlock Text="Action needed!" 
                               LineHeight="28"
                               FontSize="24" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,24"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="InteractionMessageTextBlock" 
                               FontSize="16" 
                               TextWrapping="Wrap" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center"
                               Margin="0,0,0,32"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:Button Content="Done!" 
                                   Appearance="Primary" 
                                   Width="140" 
                                   Height="40"
                                   Margin="0,0,16,0"
                                   Click="GlobalInteractionDone_Click"/>
                        <ui:Button Content="Cancel" 
                                   Width="140" 
                                   Height="40"
                                   Click="GlobalInteractionCancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Grid>
</ui:FluentWindow>
