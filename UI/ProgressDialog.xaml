    <ui:ContentDialog x:Class="Kirin_Tool.UI.ProgressDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:models="clr-namespace:Kirin_Tool.Models"
                  mc:Ignorable="d"
                  d:DataContext="{d:DesignInstance Type=models:ProgressItemViewModel, IsDesignTimeCreatable=False}"
                  Title="Unlock in Progress"
                  PrimaryButtonText=""
                  IsPrimaryButtonEnabled="False"
                  DialogWidth="700"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

    <Border Background="White" CornerRadius="8" BorderBrush="LightGray" BorderThickness="1">
        <StackPanel Margin="32,24,32,24">
            <ItemsControl ItemsSource="{Binding ProgressItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                     Text="{Binding FileName}" 
                                     VerticalAlignment="Center" 
                                     FontWeight="SemiBold" 
                                     ToolTip="{Binding FileName}"
                                     Margin="0,0,16,0"/>
                            <ProgressBar Grid.Column="1" 
                                       Value="{Binding ProgressValue}" 
                                       Margin="16,0,16,0" 
                                       VerticalAlignment="Center" 
                                       Height="12"
                                       MinWidth="200"/>

                            <TextBlock Grid.Column="2" 
                                     Text="{Binding StatusText}" 
                                     VerticalAlignment="Center" 
                                     HorizontalAlignment="Center" 
                                     Foreground="Gray"
                                     Margin="16,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Margin="0,32,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Name="OverallStatusTextBlock" 
                         Grid.Column="0"
                         Text="Initializing..." 
                         Foreground="DimGray" 
                         TextWrapping="Wrap"
                         FontSize="14"
                         VerticalAlignment="Center"/>

                <ui:Button Name="CloseButton"
                           Grid.Column="1"
                           Content="OK"
                           Appearance="Primary"
                           Width="80"
                           Height="32"
                           Margin="16,0,0,0"
                           Visibility="Collapsed"
                           Click="CloseButton_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</ui:ContentDialog>
