    <ui:ContentDialog x:Class="Kirin_Tool.UI.ProcessDialogUapp"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  mc:Ignorable="d"
                  Title="Flashing UPDATE.APP Partitions"
                  DialogWidth="900"
                  DialogHeight="550"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Background="White">

    <ui:ContentDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </ui:ContentDialog.Resources>

    <Border Background="White" 
            CornerRadius="8" 
            BorderBrush="LightGray" 
            BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                          Text="{Binding OverallStatusText}" 
                          FontSize="16"
                          FontWeight="SemiBold"
                          Foreground="Black"
                          Margin="0,0,0,10"/>

                <ProgressBar Grid.Row="1"
                            Value="{Binding OverallProgress}"
                            Maximum="100"
                            Height="8"
                            Background="LightGray"
                            Foreground="DodgerBlue"/>
            </Grid>

            <ScrollViewer Grid.Row="1" 
                         x:Name="PartitionScrollViewer"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Background="White"
                         BorderBrush="LightGray"
                         BorderThickness="1"
                         Padding="12"
                         MaxHeight="350">

                <ItemsControl ItemsSource="{Binding PartitionItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="PartitionBorder"
                                   Margin="0,4"
                                   Padding="16,12"
                                   Background="{Binding BackgroundBrush}"
                                   BorderBrush="{Binding BorderBrush}"
                                   BorderThickness="2"
                                   CornerRadius="8">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Column="0"
                                            Width="24" 
                                            Height="24"
                                            Fill="{Binding StatusColor}"
                                            VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                              Text="{Binding Name}"
                                              FontSize="14"
                                              FontWeight="SemiBold"
                                              Foreground="Black"
                                              VerticalAlignment="Center"
                                              Margin="8,0,0,0"/>

                                    <TextBlock Grid.Column="2"
                                              Text="{Binding FormattedSize}"
                                              FontSize="12"
                                              Foreground="Gray"
                                              VerticalAlignment="Center"
                                              Margin="8,0,0,0"/>

                                    <TextBlock Grid.Column="3"
                                              Text="{Binding StatusText}"
                                              FontSize="12"
                                              Foreground="Black"
                                              VerticalAlignment="Center"
                                              Margin="8,0,0,0"/>

                                    <TextBlock Grid.Column="4"
                                              Text="{Binding TimeElapsed}"
                                              FontSize="11"
                                              Foreground="DarkGray"
                                              VerticalAlignment="Center"
                                              Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="2"
                      Text="{Binding CurrentOperationText}"
                      FontSize="14"
                      Foreground="Black"
                      Margin="0,20,0,10"
                      HorizontalAlignment="Center"
                      FontWeight="Medium"/>

            <StackPanel Grid.Row="3" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Right" 
                       Margin="0,10,0,0">

                <ui:Button x:Name="CancelButton"
                          Content="Cancel"
                          Margin="0,0,10,0"
                          MinWidth="100"
                          IsEnabled="{Binding CanCancel}"
                          Click="CancelButton_Click"/>

                <ui:Button x:Name="CloseButton"
                          Content="Close"
                          MinWidth="100"
                          Visibility="{Binding ShowCloseButton, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Appearance="Primary"
                          Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</ui:ContentDialog>
