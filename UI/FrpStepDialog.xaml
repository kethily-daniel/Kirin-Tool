    <ui:ContentDialog x:Class="Kirin_Tool.UI.FrpStepDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  mc:Ignorable="d"
                  Title="FRP Lock removal in Progress"
                  PrimaryButtonText=""
                  IsPrimaryButtonEnabled="False"
                  DialogWidth="450"
                  DialogHeight="300"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">

    <Border Background="White" CornerRadius="8" BorderBrush="LightGray" BorderThickness="1">
        <StackPanel Margin="32,24,32,24">
            <Grid Margin="0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                          Text="Step 1:" 
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>

                <ui:SymbolIcon Grid.Column="2"
                              x:Name="Step1Icon"
                              Symbol="Clock24"
                              Foreground="Gray"
                              FontSize="20"/>
            </Grid>

            <Grid Margin="0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                          Text="Step 2:" 
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>

                <ui:SymbolIcon Grid.Column="2"
                              x:Name="Step2Icon"
                              Symbol="Clock24"
                              Foreground="Gray"
                              FontSize="20"/>
            </Grid>

            <Grid Margin="0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                          Text="Step 3:" 
                          FontWeight="SemiBold"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>

                <ui:SymbolIcon Grid.Column="2"
                              x:Name="Step3Icon"
                              Symbol="Clock24"
                              Foreground="Gray"
                              FontSize="20"/>
            </Grid>

            <Grid Margin="0,32,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Name="OverallStatusTextBlock" 
                         Grid.Column="0"
                         Text="Initializing FRP Lock removal..." 
                         Foreground="DimGray" 
                         TextWrapping="Wrap"
                         FontSize="14"
                         VerticalAlignment="Center"/>

                <ui:Button Name="CloseButton"
                           Grid.Column="1"
                           Content="OK"
                           Appearance="Primary"
                           Width="80"
                           Height="32"
                           Margin="16,0,0,0"
                           Visibility="Collapsed"
                           Click="CloseButton_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</ui:ContentDialog>
